<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="false">  <!-- Change to parallel="false" -->

    <listeners>
        <listener class-name="karunasagarlearning.TestComponent.Listeners"/>
    </listeners>

    <test name="Submit Order Test" preserve-order="true">  <!-- Add preserve-order -->
        <groups>
            <run>
                <include name="Purchase"/>
            </run>
        </groups>
        <classes>
            <class name="karunasagarlearning.Test.SubmitOrderTest"/>
        </classes>
    </test>

</suite>